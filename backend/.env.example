PORT=3001
FRONTEND_URL=http://localhost:3000
ROSS_ENV=local
# self-hosted (local/default), controlled-beta, or production.
ROSS_HOSTED_MODE=self-hosted
ROSS_DATA_BOUNDARY_VERSION=2026-07-16
# Public hosted beta only: reject API sessions until Supabase confirms email.
ROSS_REQUIRE_VERIFIED_EMAIL=false
# Required in hosted modes; list only reviewed provider configurations.
HOSTED_MODEL_PROVIDERS=
# Production remains fail-closed until recorded legal/privacy/security approvals.
ROSS_PRODUCTION_CONTROLS_APPROVED=false
# Required in production and must identify the exact approved candidate and the
# SHA-256 digest of its governed release manifest. These values are evidence
# references, not substitutes for npm run release:check.
ROSS_RELEASE_ID=
ROSS_RELEASE_MANIFEST_SHA256=
# Comma-separated exact browser origins. FRONTEND_URL remains a compatibility fallback.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# HMAC key used to sign /download/:token URLs. Required at startup.
# Generate with: openssl rand -hex 32
# Use a dedicated secret distinct from SUPABASE_SECRET_KEY.
DOWNLOAD_SIGNING_SECRET=replace-with-a-random-32-byte-hex-string
# Optional overlap key during a controlled rotation; remove it after the
# longest issued token lifetime has elapsed.
DOWNLOAD_SIGNING_SECRET_PREVIOUS=
# Download tokens default to 24 hours and are always capped at 7 days.
DOWNLOAD_TOKEN_TTL_SECONDS=86400
# Optional Unix timestamp that revokes every token issued before it.
DOWNLOAD_TOKEN_NOT_BEFORE=0
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# Supabase Storage S3 configuration from Project Settings > Storage.
# The historical R2_* names remain for compatibility with the inherited app.
R2_ENDPOINT_URL=https://your-project-ref.storage.supabase.co/storage/v1/s3
R2_REGION=ca-central-1
R2_ACCESS_KEY_ID=your-supabase-storage-s3-access-key
R2_SECRET_ACCESS_KEY=your-supabase-storage-s3-secret-key
R2_BUCKET_NAME=ross-private-files

# Hosted upload scanning. The worker is private and receives only short-lived,
# object-specific signed URLs; it must not receive Supabase service credentials.
FILE_WORKER_URL=http://your-file-worker.flycast:3002
FILE_WORKER_SHARED_SECRET=replace-with-a-random-32-byte-hex-string
FILE_WORKER_POLL_INTERVAL_MS=15000
FILE_WORKER_STORAGE_ORIGINS=https://your-project-ref.storage.supabase.co
ROSS_UPLOAD_SCAN_REQUIRED=false

# Metadata-only operator alert endpoint for infected files and final failures.
SECURITY_ALERT_WEBHOOK_URL=https://your-alert-endpoint.example.invalid/ross
SECURITY_ALERT_WEBHOOK_SECRET=replace-with-a-separate-random-secret

GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
RESEND_API_KEY=your-resend-key
USER_API_KEYS_ENCRYPTION_SECRET=your-long-random-secret

# Optional: enables higher-rate CourtListener case law/citation lookup tools.
COURTLISTENER_API_TOKEN=your-courtlistener-token

# Licensed-source connectors are disabled by default. Do not enable without an
# executed provider agreement and an approved transport adapter.
CANLII_CONNECTOR_ENABLED=false
CANLII_CONTRACT_ID=
CANLII_ORGANIZATION_ID=
CANLII_API_KEY=
CANLII_API_BASE_URL=
CANLII_APPROVED_TRANSPORT=
CANLII_ALLOWED_OPERATIONS=
CANLII_FULL_TEXT_ENTITLED=false
CANLII_METADATA_RETENTION_DAYS=0
CANLII_FULL_TEXT_RETENTION_DAYS=0
CANLII_REDISTRIBUTION_ALLOWED=false
